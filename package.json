{
  "name": "seance-search",
  "version": "1.0.0",
  "description": "A Desktop Necromancer for the Dead Internet",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder --win --publish never",
    "build:zip": "electron-builder --win zip --publish never",
    "pack": "electron-builder --dir --publish never"
  },
  "build": {
    "appId": "com.seance.search",
    "productName": "SÉANCE SEARCH",
    "executableName": "SEANCE-SEARCH",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraFiles": [],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": null,
      "signingHashAlgorithms": null,
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "SEANCE-SEARCH.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "express": "^4.19.2"
  }
}
